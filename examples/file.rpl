// Test File System
tampilkan("--- UJI FILE SYSTEM ---")
buat tulisan = "Halo dari RPL! Bahasa pemrograman buatan Indonesia."
buat hasil = file.tulis("tes.txt", tulisan)
jika hasil == benar maka
    tampilkan("Berhasil menulis file tes.txt")
selesai

jika file.ada("tes.txt") == benar maka
    buat isi = file.baca("tes.txt")
    tampilkan("Isi file tes.txt:")
    tampilkan(isi)
selesai
