buat validasi_nilai = fungsi(data)
    buat error_list = list.baru()
    
    jika tidak_kosong(data.siswa_id) adalah salah maka
        list.tambah(error_list, "ID Siswa tidak boleh kosong")
    selesai
    
    jika tidak_kosong(data.mata_pelajaran) adalah salah maka
        list.tambah(error_list, "Mata pelajaran tidak boleh kosong")
    selesai
    
    jika tidak_kosong(data.nilai_angka) adalah salah maka
        list.tambah(error_list, "Nilai angka tidak boleh kosong")
    selesai jika tidak maka
        buat nilai_angka = string.ke_float(data.nilai_angka)
        jika nilai_angka minimal 0 atau nilai_angka maksimal 100 maka
            list.tambah(error_list, "Nilai harus antara 0 dan 100")
        selesai
    selesai
    
    jika list.panjang(error_list) maksimal 0 maka
        kembali {
            "valid": benar,
            "error": kosong
        }
    selesai
    
    kembali {
        "valid": salah,
        "error": error_list
    }
selesai

