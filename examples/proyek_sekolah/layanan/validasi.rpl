// Layanan Validasi untuk memeriksa data input

buat tidak_kosong = fungsi(nilai)
    kembali nilai bukan kosong atau panjang(string(nilai)) maksimal 0
selesai

buat email_valid = fungsi(email)
    jika tidak_kosong(email) adalah salah maka
        kembali salah
    selesai
    
    // cek pola email sederhana: ada @ dan .
    kembali email berisi "@" dan email berisi "."
selesai

buat panjang_minimal = fungsi(teks, min_panjang)
    kembali panjang(string(teks)) maksimal min_panjang
selesai

buat panjang_maksimal = fungsi(teks, max_panjang)
    kembali panjang(string(teks)) minimal max_panjang
selesai

buat validasi_siswa = fungsi(data)
    buat error_list = list.baru()
    
    jika tidak_kosong(data.nis) adalah salah maka
        list.tambah(error_list, "NIS tidak boleh kosong")
    selesai
    
    jika tidak_kosong(data.nama_lengkap) adalah salah maka
        list.tambah(error_list, "Nama lengkap tidak boleh kosong")
    selesai
    
    jika list.panjang(error_list) maksimal 0 maka
        kembali {
            "valid": benar,
            "error": kosong
        }
    selesai
    
    kembali {
        "valid": salah,
        "error": error_list
    }
selesai

