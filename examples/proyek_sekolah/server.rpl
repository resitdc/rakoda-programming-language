tampilkan("🛤️  Mendaftarkan rute...")

// --- HALAMAN TAMPILAN ---

// Dashboard
web.dapatkan("/", fungsi(req)
    kembalikan web.tampilkan_halaman("tampilan/index.rpl.html")
selesai)

// Halaman Login
web.dapatkan("/login", fungsi(req)
    kembalikan web.tampilkan_halaman("tampilan/login.rpl.html")
selesai)

// ========================
// AUTH (Otentikasi)
// ========================

web.pos("/api/auth/login", login)
web.pos("/api/auth/logout", logout)
web.pos("/api/auth/register-admin", register_admin)
web.taruh("/api/auth/ganti-password", ganti_password)
web.dapatkan("/api/auth/sesi", cek_sesi)
web.dapatkan("/api/auth/users", daftar_user)
web.taruh("/api/auth/users/{id}/nonaktifkan", nonaktifkan_user)
web.taruh("/api/auth/users/{id}/aktifkan", aktifkan_user)

// ========================
// SISWA
// ========================

// CRUD
web.dapatkan("/api/siswa", ambil_semua)
web.dapatkan("/api/siswa/{id}", ambil_detail)
web.pos("/api/siswa", tambah)
web.taruh("/api/siswa/{id}", perbarui)
web.hapus("/api/siswa/{id}", hapus)

// Pencarian & Filter
web.dapatkan("/api/siswa/cari", cari)
web.dapatkan("/api/siswa/per-kelas/{kelas_id}", per_kelas)
web.dapatkan("/api/siswa/statistik", statistik)

// ========================
// GURU
// ========================

// CRUD
web.dapatkan("/api/guru", ambil_semua_guru)
