fungsi catat(req)
    buat data = req.body
    buat val = validasi_wajib(data, ["siswa_id", "tanggal", "status"])
    
    jika val.sukses == salah
        kembalikan val
    selesai
    
    // Validasi status
    buat status_valid = ["hadir", "sakit", "izin", "alpa"]
    buat status_ditemukan = salah
    buat i = 0
    selama i < panjang(status_valid)
        jika data.status == status_valid[i]
            status_ditemukan = benar
        selesai
        i = i + 1
    selesai
    
    jika status_ditemukan == salah
        kembalikan error("Status harus: hadir, sakit, izin, atau alpa", 400)
    selesai
    
    db.jalankan("MASUKKAN KE absensi (siswa_id, kelas_id, tanggal, status, keterangan) NILAI ('" + data.siswa_id + "', '" + data.kelas_id + "', '" + data.tanggal + "', '" + data.status + "', '" + data.keterangan + "')")
    
    kembalikan sukses("Absensi berhasil dicatat")
selesai

