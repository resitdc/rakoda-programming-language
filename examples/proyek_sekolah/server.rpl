// ================================
// INLINE: Kontroler NILAI
// ================================

fungsi ambil_semua_nilai(req)
    buat hasil_query = db.jalankan("SELECT n.*, s.nama_lengkap as nama_siswa, k.nama_mapel FROM nilai n JOIN siswa s ON n.siswa_id = s.id LEFT JOIN kelas k ON n.kelas_id = k.id ORDER BY n.dibuat_pada DESC LIMIT 100")
    kembalikan hasil_query
selesai

fungsi tambah_nilai(req)
    buat data = req.body
    buat val = validasi_wajib(data, ["siswa_id", "mapel", "semester", "nilai_angka"])
    
    jika val.sukses == salah
        kembalikan val
    selesai
    
    // Validasi range nilai
    buat nilai_angka = data.nilai_angka
    jika nilai_angka < 0 atau nilai_angka > 100
        kembalikan error("Nilai harus antara 0-100", 400)
    selesai
    
    db.jalankan("MASUKKAN KE nilai (siswa_id, kelas_id, mapel, semester, tipe, nilai_angka, keterangan) NILAI ('" + data.siswa_id + "', '" + data.kelas_id + "', '" + data.mapel + "', '" + data.semester + "', '" + data.tipe + "', '" + data.nilai_angka + "', '" + data.keterangan + "')")
    
    kembalikan sukses("Nilai berhasil ditambahkan")
selesai

fungsi perbarui_nilai(req)
    buat id_nilai = req.param.id
    buat data = req.body
    
    buat cek = db.jalankan("SELECT id FROM nilai WHERE id = " + id_nilai)
    jika panjang(cek) == 0
        kembalikan error("Nilai tidak ditemukan", 404)
    selesai
    
    // Validasi range nilai
    buat nilai_angka = data.nilai_angka
    jika nilai_angka < 0 atau nilai_angka > 100
        kembalikan error("Nilai harus antara 0-100", 400)
    selesai
    
    db.jalankan("PERBARUI nilai SET nilai_angka = '" + data.nilai_angka + "', tipe = '" + data.tipe + "', keterangan = '" + data.keterangan + "' WHERE id = " + id_nilai)
    
    kembalikan sukses("Nilai berhasil diperbarui")
selesai

fungsi hapus_nilai(req)
    buat id_nilai = req.param.id
    
    buat cek = db.jalankan("SELECT id FROM nilai WHERE id = " + id_nilai)
    jika panjang(cek) == 0
        kembalikan error("Nilai tidak ditemukan", 404)
    selesai
    
    db.jalankan("HAPUS DARI nilai WHERE id = " + id_nilai)
    
    kembalikan sukses("Nilai berhasil dihapus")
selesai

fungsi rekap_siswa(req)
    buat siswa_id = req.param.siswa_id
    
    buat data_siswa = db.jalankan("SELECT nama_lengkap FROM siswa WHERE id = " + siswa_id)
    jika panjang(data_siswa) == 0
        kembalikan error("Siswa tidak ditemukan", 404)
    selesai
    
    buat daftar_nilai = db.jalankan("SELECT n.*, k.nama_mapel FROM nilai n LEFT JOIN kelas k ON n.kelas_id = k.id WHERE n.siswa_id = " + siswa_id + " ORDER BY n.semester, n.nama_mapel")
    
    buat rata_rata = hitung_rata_rata(daftar_nilai)
    buat nilai_huruf = konversi_huruf(rata_rata)
    
    kembalikan { siswa: data_siswa[0], daftar_nilai: daftar_nilai, rata_rata: rata_rata, nilai_huruf: nilai_huruf }
selesai

fungsi peringkat_kelas(req)
    buat kelas_id = req.param.kelas_id
    
    buat daftar_siswa = db.jalankan("SELECT s.id, s.nama_lengkap FROM siswa s JOIN kelas_siswa ks ON s.id = ks.siswa_id WHERE ks.kelas_id = " + kelas_id)
    
    buat hasil_mentah = []
    buat i = 0
    selama i < panjang(daftar_siswa)
        buat s = daftar_siswa[i]
        buat nilai_siswa = db.jalankan("SELECT nilai_angka FROM nilai WHERE siswa_id = " + s.id)
        buat rata = hitung_rata_rata(nilai_siswa)
        
        hasil_mentah = list.tambah(hasil_mentah, { id: s.id, nama: s.nama_lengkap, rata_rata: rata })
        i = i + 1
    selesai
    
    // Urutkan dengan insertion sort descending (bangun list baru)
    buat hasil_peringkat = []
    i = 0
    selama i < panjang(hasil_mentah)
        buat item_skrg = hasil_mentah[i]
        // Cari posisi sisip
        buat pos = 0
        buat disisip = salah
        buat hasil_baru = []
        buat j = 0
        selama j < panjang(hasil_peringkat)
            buat ada = hasil_peringkat[j]
            jika disisip == salah dan item_skrg.rata_rata > ada.rata_rata
                hasil_baru = list.tambah(hasil_baru, item_skrg)
                disisip = benar
            selesai
            hasil_baru = list.tambah(hasil_baru, ada)
            j = j + 1
        selesai
        jika disisip == salah
            hasil_baru = list.tambah(hasil_baru, item_skrg)
        selesai
        hasil_peringkat = hasil_baru
        i = i + 1
    selesai
    
    kembalikan sukses(hasil_peringkat)
selesai

fungsi rekap_mapel(req)
    buat hasil_query = db.jalankan("SELECT mapel, semester, COUNT(*) as total_entri, AVG(nilai_angka) as rata_rata FROM nilai GROUP BY mapel, semester ORDER BY mapel, semester")
    kembalikan hasil_query
selesai

