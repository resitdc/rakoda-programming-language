// Skema Database Sekolah
// Tabel: users, siswa, guru, kelas, kelas_siswa, nilai, absensi, jadwal, pengumuman

tampilkan("🔧 Membuat tabel database sekolah...")

// 1. Tabel users (untuk auth)
db.jalankan("
    BUAT TABEL JIKA BELUM ADA users (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        nama_pengguna TEXT NOT NULL UNIQUE,
        kata_sandi TEXT NOT NULL,
        peran TEXT NOT NULL DEFAULT 'guru',
        nama_lengkap TEXT,
        status BOOLEAN DEFAULT 'aktif',
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
")

// 2. Tabel guru
db.jalankan("
    BUAT TABEL JIKA BELUM ADA guru (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        nip TEXT UNIQUE,
        nama_lengkap TEXT NOT NULL,
        bidang_studi TEXT,
        email TEXT,
        telepon TEXT,
        alamat TEXT,
        status TEXT DEFAULT 'aktif',
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
")

// 3. Tabel kelas
db.jalankan("
    BUAT TABEL JIKA BELUM ADA kelas (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        nama_kelas TEXT NOT NULL,
        nama_mapel TEXT NOT NULL,
        tahun_ajaran TEXT NOT NULL,
        guru_id INTEGER,
        kapasitas INTEGER DEFAULT 40,
        status TEXT DEFAULT 'aktif',
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (guru_id) REFERENCES guru(id)
    )
")

// 4. Tabel siswa
db.jalankan("
    BUAT TABEL JIKA BELUM ADA siswa (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        nisn TEXT UNIQUE,
        nis TEXT UNIQUE,
        nama_lengkap TEXT NOT NULL,
        tempat_lahir TEXT,
        tanggal_lahir TEXT,
        jenis_kelamin TEXT,
        alamat TEXT,
        telepon TEXT,
        email TEXT,
        nama_wali TEXT,
        tahun_masuk INTEGER,
        status TEXT DEFAULT 'aktif',
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
")

// 5. Tabel kelas_siswa (relasi many-to-many)
db.jalankan("
    BUAT TABEL JIKA BELUM ADA kelas_siswa (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        kelas_id INTEGER NOT NULL,
        siswa_id INTEGER NOT NULL,
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (kelas_id) REFERENCES kelas(id),
        FOREIGN KEY (siswa_id) REFERENCES siswa(id),
        UNIQUE(kelas_id, siswa_id)
    )
")

// 6. Tabel nilai
db.jalankan("
    BUAT TABEL JIKA BELUM ADA nilai (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        siswa_id INTEGER NOT NULL,
        kelas_id INTEGER,
        mapel TEXT NOT NULL,
        semester TEXT NOT NULL,
        tipe TEXT NOT NULL DEFAULT 'uts',
        nilai_angka REAL NOT NULL,
        keterangan TEXT,
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (siswa_id) REFERENCES siswa(id),
        FOREIGN KEY (kelas_id) REFERENCES kelas(id)
    )
")

// 7. Tabel absensi
db.jalankan("
    BUAT TABEL JIKA BELUM ADA absensi (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        siswa_id INTEGER NOT NULL,
        kelas_id INTEGER,
        tanggal TEXT NOT NULL,
        status TEXT NOT NULL DEFAULT 'hadir',
        keterangan TEXT,
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (siswa_id) REFERENCES siswa(id),
        FOREIGN KEY (kelas_id) REFERENCES kelas(id)
    )
")

// 8. Tabel jadwal
db.jalankan("
    BUAT TABEL JIKA BELUM ADA jadwal (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        kelas_id INTEGER NOT NULL,
        hari TEXT NOT NULL,
        jam_mulai TEXT NOT NULL,
        jam_selesai TEXT NOT NULL,
        mapel TEXT NOT NULL,
        guru_id INTEGER,
        ruangan TEXT,
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (kelas_id) REFERENCES kelas(id),
        FOREIGN KEY (guru_id) REFERENCES guru(id)
    )
")

// 9. Tabel pengumuman
db.jalankan("
    BUAT TABEL JIKA BELUM ADA pengumuman (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        judul TEXT NOT NULL,
        isi TEXT NOT NULL,
        prioritas TEXT DEFAULT 'normal',
        target_kelas_id INTEGER,
        pembuat TEXT,
        tanggal_mulai TEXT,
        tanggal_selesai TEXT,
        status TEXT DEFAULT 'aktif',
        dibuat_pada TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (target_kelas_id) REFERENCES kelas(id)
    )
")

tampilkan("✅ Database berhasil diinisialisasi")

