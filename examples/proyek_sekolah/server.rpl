// ================================
// INLINE: Kontroler AUTH
// ================================

fungsi login(req)
    buat data = req.body
    buat val = validasi_wajib(data, ["nama_pengguna", "kata_sandi"])
    
    jika val.sukses == salah
        kembalikan val
    selesai
    
    // Hash password terlebih dahulu
    buat password_hash = kripto.sha256(data.kata_sandi)
    
    buat hasil_query = db.jalankan("SELECT * FROM users WHERE nama_pengguna = '" + data.nama_pengguna + "' AND kata_sandi = '" + password_hash + "' AND status = 'aktif'")
    
    jika panjang(hasil_query) == 0
        kembalikan error("Username atau password salah", 401)
    selesai
    
    buat user = hasil_query[0]
    buat token = buat_token(user.id, user.peran)
    
    buat hasil = { token: token, user: { id: user.id, nama_pengguna: user.nama_pengguna, peran: user.peran, nama_lengkap: user.nama_lengkap } }
    
    kembalikan sukses("Login berhasil", hasil)
selesai

fungsi logout(req)
    kembalikan sukses("Logout berhasil")
selesai

fungsi register_admin(req)
    buat data = req.body
    buat val = validasi_wajib(data, ["nama_pengguna", "kata_sandi", "nama_lengkap"])
    
    jika val.sukses == salah
        kembalikan val
    selesai
    
    // Cek apakah user sudah ada
    buat cek = db.jalankan("SELECT id FROM users WHERE nama_pengguna = '" + data.nama_pengguna + "'")
    jika panjang(cek) > 0
        kembalikan error("Username sudah digunakan", 400)
    selesai
    
    buat password_hash = kripto.sha256(data.kata_sandi)
    
    db.jalankan("MASUKKAN KE users (nama_pengguna, kata_sandi, peran, nama_lengkap) NILAI ('" + data.nama_pengguna + "', '" + password_hash + "', '" + data.peran + "', '" + data.nama_lengkap + "')")
    
    kembalikan sukses("User berhasil didaftarkan")
selesai

fungsi ganti_password(req)
    buat data = req.body
    
    buat password_lama_hash = kripto.sha256(data.password_lama)
    buat password_baru_hash = kripto.sha256(data.password_baru)
    
    // Cek password lama
    buat cek = db.jalankan("SELECT id FROM users WHERE nama_pengguna = '" + data.nama_pengguna + "' AND kata_sandi = '" + password_lama_hash + "'")
    jika panjang(cek) == 0
        kembalikan error("Password lama salah", 401)
    selesai
    
    db.jalankan("PERBARUI users SET kata_sandi = '" + password_baru_hash + "' WHERE nama_pengguna = '" + data.nama_pengguna + "'")
    
    kembalikan sukses("Password berhasil diganti")
selesai

fungsi cek_sesi(req)
    // Endpoint simpel untuk cek apakah user masih login
    kembalikan sukses("Sesi aktif")
selesai

fungsi daftar_user(req)
