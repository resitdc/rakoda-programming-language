// ================================
// INLINE: Model Response
// ================================

fungsi sukses(pesan, data)
    jika data != kosong
        kembalikan { pesan: pesan, sukses: true, data: data }
    selesai
    kembalikan { pesan: pesan, sukses: true }
selesai

fungsi error(pesan, kode)
    jika kode != kosong
        kembalikan { pesan: pesan, sukses: false, kode: kode }
    selesai
    kembalikan { pesan: pesan, sukses: false }
selesai

// ================================
// INLINE: Layanan Validasi
// ================================

fungsi validasi_wajib(data, daftar_field)
    buat i = 0
    selama i < panjang(daftar_field)
        buat field = daftar_field[i]
        buat nilai = data[field]
        
        jika nilai == kosong atau nilai == ""
            kembalikan error("Field '" + field + "' wajib diisi", 400)
        selesai
        
        i = i + 1
    selesai
    
    kembalikan sukses("Validasi berhasil")
selesai

fungsi validasi_panjang(nilai, min, maks, nama_field)
    buat p = panjang(nilai)
    
    jika p < min
        kembalikan error(nama_field + " minimal " + min + " karakter", 400)
    selesai
    
    jika p > maks
        kembalikan error(nama_field + " maksimal " + maks + " karakter", 400)
    selesai
    
    kembalikan sukses("Panjang valid")
selesai

// ================================
// INLINE: Layanan Hitung Nilai
// ================================

fungsi hitung_rata_rata(daftar_nilai)
    jika panjang(daftar_nilai) == 0
        kembalikan 0
    selesai
    
    buat total = 0
    buat i = 0
    selama i < panjang(daftar_nilai)
        buat item = daftar_nilai[i]
        total = total + item.nilai_angka
        i = i + 1
    selesai
    
    kembalikan total / panjang(daftar_nilai)
selesai

fungsi konversi_huruf(nilai_angka)
    jika nilai_angka >= 90
        kembalikan "A"
    selesai
    jika nilai_angka >= 80
        kembalikan "B"
    selesai
    jika nilai_angka >= 70
        kembalikan "C"
    selesai
    jika nilai_angka >= 60
        kembalikan "D"
    selesai
    kembalikan "E"
selesai

fungsi cek_naik_kelas(nilai_rata_rata, absensi_hadir, total_absensi)
    jika nilai_rata_rata >= 70 dan absensi_hadir / total_absensi >= 0.75
        kembalikan benar
    selesai
    kembalikan salah
selesai

// ================================
// INLINE: Layanan Auth Helper
// ================================

fungsi buat_token(user_id, peran)
    buat payload = user_id + ":" + peran + ":" + string.dari(waktu.sekarang())
    kembalikan string.ke_base64(payload)
selesai

fungsi hash_password(password)
    kembalikan kripto.sha256(password)
selesai

// ================================
// INLINE: Kontroler SISWA
// ================================

fungsi ambil_semua(req)
    buat hasil_query = db.jalankan("SELECT * FROM siswa WHERE status = 'aktif' ORDER BY nama_lengkap ASC")
    kembalikan hasil_query
selesai

fungsi ambil_detail(req)
    buat id_siswa = req.param.id
    buat hasil_query = db.jalankan("SELECT * FROM siswa WHERE id = " + id_siswa)
    
    jika panjang(hasil_query) == 0
        kembalikan error("Siswa tidak ditemukan", 404)
    selesai
    
    kembalikan hasil_query[0]
selesai

fungsi tambah(req)
    buat data = req.body
    buat val = validasi_wajib(data, ["nisn", "nis", "nama_lengkap"])
    
    jika val.sukses == salah
        kembalikan val
    selesai
    
    db.jalankan("MASUKKAN KE siswa (nisn, nis, nama_lengkap, tempat_lahir, tanggal_lahir, jenis_kelamin, alamat, telepon, email, nama_wali, tahun_masuk) NILAI ('" + data.nisn + "', '" + data.nis + "', '" + data.nama_lengkap + "', '" + data.tempat_lahir + "', '" + data.tanggal_lahir + "', '" + data.jenis_kelamin + "', '" + data.alamat + "', '" + data.telepon + "', '" + data.email + "', '" + data.nama_wali + "', '" + data.tahun_masuk + "')")
    
    kembalikan sukses("Siswa berhasil ditambahkan")
selesai

fungsi perbarui(req)
    buat id_siswa = req.param.id
    buat data = req.body
    
    // Periksa apakah siswa ada
    buat cek = db.jalankan("SELECT id FROM siswa WHERE id = " + id_siswa)
    jika panjang(cek) == 0
        kembalikan error("Siswa tidak ditemukan", 404)
    selesai
    
    db.jalankan("PERBARUI siswa SET nisn = '" + data.nisn + "', nis = '" + data.nis + "', nama_lengkap = '" + data.nama_lengkap + "', tempat_lahir = '" + data.tempat_lahir + "', tanggal_lahir = '" + data.tanggal_lahir + "', jenis_kelamin = '" + data.jenis_kelamin + "', alamat = '" + data.alamat + "', telepon = '" + data.telepon + "', email = '" + data.email + "', nama_wali = '" + data.nama_wali + "', tahun_masuk = '" + data.tahun_masuk + "' WHERE id = " + id_siswa)
    
    kembalikan sukses("Siswa berhasil diperbarui")
selesai

fungsi hapus(req)
    buat id_siswa = req.param.id
    
    buat cek = db.jalankan("SELECT id FROM siswa WHERE id = " + id_siswa)
    jika panjang(cek) == 0
        kembalikan error("Siswa tidak ditemukan", 404)
    selesai
    
    db.jalankan("HAPUS DARI siswa WHERE id = " + id_siswa)
    
    kembalikan sukses("Siswa berhasil dihapus")
selesai

fungsi cari(req)
    buat kata_kunci = req.query.q
    
    jika kata_kunci == kosong atau kata_kunci == ""
        kembalikan error("Kata kunci pencarian diperlukan", 400)
    selesai
    
    buat hasil_query = db.jalankan("SELECT * FROM siswa WHERE (nama_lengkap LIKE '%" + kata_kunci + "%' OR nisn LIKE '%" + kata_kunci + "%' OR nis LIKE '%" + kata_kunci + "%') AND status = 'aktif' ORDER BY nama_lengkap ASC")
    
    kembalikan hasil_query
selesai

fungsi per_kelas(req)
    buat kelas_id = req.param.kelas_id
    
    buat hasil_query = db.jalankan("SELECT s.* FROM siswa s JOIN kelas_siswa ks ON s.id = ks.siswa_id WHERE ks.kelas_id = " + kelas_id + " AND s.status = 'aktif' ORDER BY s.nama_lengkap ASC")
    
    kembalikan hasil_query
selesai

fungsi statistik(req)
    buat total_siswa = db.jalankan("SELECT COUNT(*) as jumlah FROM siswa WHERE status = 'aktif'")
    buat per_kelas = db.jalankan("SELECT k.nama_kelas, COUNT(ks.siswa_id) as jumlah_siswa FROM kelas k LEFT JOIN kelas_siswa ks ON k.id = ks.kelas_id GROUP BY k.id ORDER BY k.nama_kelas")
    buat per_tahun = db.jalankan("SELECT tahun_masuk, COUNT(*) as jumlah FROM siswa WHERE status = 'aktif' GROUP BY tahun_masuk ORDER BY tahun_masuk DESC")
    
    kembalikan { total: total_siswa[0].jumlah, per_kelas: per_kelas, per_tahun: per_tahun }
selesai

