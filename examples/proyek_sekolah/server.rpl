fungsi rekap_siswa_absensi(req)
    buat siswa_id = req.param.siswa_id
    
    buat total = db.jalankan("SELECT COUNT(*) as total FROM absensi WHERE siswa_id = " + siswa_id)
    buat hadir = db.jalankan("SELECT COUNT(*) as jumlah FROM absensi WHERE siswa_id = " + siswa_id + " AND status = 'hadir'")
    buat sakit = db.jalankan("SELECT COUNT(*) as jumlah FROM absensi WHERE siswa_id = " + siswa_id + " AND status = 'sakit'")
    buat izin = db.jalankan("SELECT COUNT(*) as jumlah FROM absensi WHERE siswa_id = " + siswa_id + " AND status = 'izin'")
    buat alpa = db.jalankan("SELECT COUNT(*) as jumlah FROM absensi WHERE siswa_id = " + siswa_id + " AND status = 'alpa'")
    
    buat persentase = 0
    jika total[0].total > 0
        persentase = (hadir[0].jumlah / total[0].total) * 100
    selesai
    
    kembalikan { total: total[0].total, hadir: hadir[0].jumlah, sakit: sakit[0].jumlah, izin: izin[0].jumlah, alpa: alpa[0].jumlah, persentase_kehadiran: persentase }
selesai

fungsi laporan_harian(req)
    buat tanggal = req.query.tanggal
    
    jika tanggal == kosong atau tanggal == ""
        // Gunakan tanggal hari ini
        buat sekarang = waktu.sekarang()
        tanggal = string.dari(sekarang.tahun) + "-" + string.dari(sekarang.bulan) + "-" + string.dari(sekarang.hari)
    selesai
    
    buat hasil_query = db.jalankan("SELECT a.*, s.nama_lengkap as nama_siswa FROM absensi a JOIN siswa s ON a.siswa_id = s.id WHERE a.tanggal = '" + tanggal + "' ORDER BY s.nama_lengkap")
    
    kembalikan hasil_query
selesai

fungsi laporan_bulanan(req)
    buat bulan = req.query.bulan
    buat tahun = req.query.tahun
    
    jika bulan == kosong atau tahun == kosong
        kembalikan error("Parameter bulan dan tahun diperlukan", 400)
    selesai
    
    buat periode = tahun + "-" + bulan
    
    buat hasil_query = db.jalankan("SELECT s.id, s.nama_lengkap, COUNT(CASE WHEN a.status = 'hadir' THEN 1 END) as hadir, COUNT(CASE WHEN a.status = 'sakit' THEN 1 END) as sakit, COUNT(CASE WHEN a.status = 'izin' THEN 1 END) as izin, COUNT(CASE WHEN a.status = 'alpa' THEN 1 END) as alpa, COUNT(*) as total FROM absensi a JOIN siswa s ON a.siswa_id = s.id WHERE a.tanggal LIKE '" + periode + "%' GROUP BY s.id ORDER BY s.nama_lengkap")
    
    kembalikan hasil_query
selesai

